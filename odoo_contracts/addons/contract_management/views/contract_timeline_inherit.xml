<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_contract_contract_form_timeline_inherit" model="ir.ui.view">
        <field name="name">contract.contract.form.timeline.inherit</field>
        <field name="model">contract.contract</field>
        <field name="inherit_id" ref="contract_management.view_contract_contract_form"/>
        <field name="arch" type="xml">
            <xpath expr="//separator[@string='Attachments']" position="before">
                <group col="4">
                    <separator string="Timeline" colspan="4"/>
                    <field name="message_ids" colspan="4" nolabel="1" mode="kanban">
                        <kanban create="false" delete="false" class="cm-timeline">
                            <field name="date"/>
                            <field name="author_id"/>
                            <field name="body"/>
                            <templates>
                                <t t-name="kanban-box">
                                    <div class="o_kanban_record">
                                        <div class="o_kanban_record_top">
                                            <strong><t t-esc="record.author_id.value"/></strong>
                                            <div class="text-muted"><t t-esc="record.date.value"/></div>
                                        </div>
                                        <div class="o_kanban_record_body">
                                            <t t-esc="record.body.value"/>
                                        </div>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                    </field>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
