<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_contract_cost_center_budget_kanban" model="ir.ui.view">
        <field name="name">contract.cost.center.budget.kanban</field>
        <field name="model">contract.cost.center.budget</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile o_kanban_small_column" default_group_by="budget_state">
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
                <field name="owner_user_id"/>
                <field name="monthly_budget"/>
                <field name="committed_monthly_value"/>
                <field name="monthly_variance"/>
                <field name="annual_budget"/>
                <field name="committed_annual_value"/>
                <field name="annual_variance"/>
                <field name="budget_state"/>
                <field name="last_notified_state"/>
                <field name="contract_count"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record cm-budget-card">
                            <div class="cm-budget-card-header">
                                <div>
                                    <strong><field name="name"/></strong>
                                    <div class="text-muted"><field name="code"/></div>
                                </div>
                                <field name="budget_state" widget="badge"/>
                            </div>
                            <div class="cm-budget-card-grid">
                                <div>
                                    <span class="cm-budget-card-label">Abteilung</span>
                                    <div><field name="department_id"/></div>
                                </div>
                                <div>
                                    <span class="cm-budget-card-label">Verantwortlich</span>
                                    <div><field name="owner_user_id"/></div>
                                </div>
                                <div>
                                    <span class="cm-budget-card-label">Monat</span>
                                    <div><field name="committed_monthly_value"/> / <field name="monthly_budget"/></div>
                                </div>
                                <div>
                                    <span class="cm-budget-card-label">Jahr</span>
                                    <div><field name="committed_annual_value"/> / <field name="annual_budget"/></div>
                                </div>
                                <div>
                                    <span class="cm-budget-card-label">Verträge</span>
                                    <div><field name="contract_count"/></div>
                                </div>
                                <div>
                                    <span class="cm-budget-card-label">Gemeldet</span>
                                    <div><field name="last_notified_state" widget="badge"/></div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_contract_cost_center_budget_tree" model="ir.ui.view">
        <field name="name">contract.cost.center.budget.tree</field>
        <field name="model">contract.cost.center.budget</field>
        <field name="arch" type="xml">
            <list string="Kostenstellenbudgets">
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
                <field name="owner_user_id"/>
                <field name="escalation_user_id"/>
                <field name="monthly_budget"/>
                <field name="committed_monthly_value"/>
                <field name="annual_budget"/>
                <field name="committed_annual_value"/>
                <field name="budget_state" widget="badge"/>
                <field name="last_notified_state" widget="badge"/>
                <field name="contract_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_contract_cost_center_budget_form" model="ir.ui.view">
        <field name="name">contract.cost.center.budget.form</field>
        <field name="model">contract.cost.center.budget</field>
        <field name="arch" type="xml">
            <form string="Kostenstellenbudget">
                <sheet>
                    <group col="2">
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="department_id"/>
                            <field name="owner_user_id"/>
                            <field name="escalation_user_id"/>
                            <field name="currency_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="monthly_budget"/>
                            <field name="committed_monthly_value" readonly="1"/>
                            <field name="monthly_variance" readonly="1"/>
                            <field name="budget_state" widget="badge" readonly="1"/>
                            <field name="last_notified_state" widget="badge" readonly="1"/>
                            <field name="last_notified_at" readonly="1"/>
                            <field name="contract_count" readonly="1"/>
                        </group>
                    </group>
                    <group col="2">
                        <group>
                            <field name="annual_budget"/>
                            <field name="committed_annual_value" readonly="1"/>
                            <field name="annual_variance" readonly="1"/>
                        </group>
                        <group>
                            <field name="note"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_contract_cost_center_budget_search" model="ir.ui.view">
        <field name="name">contract.cost.center.budget.search</field>
        <field name="model">contract.cost.center.budget</field>
        <field name="arch" type="xml">
            <search string="Kostenstellenbudgets">
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
                <field name="owner_user_id"/>
                <filter name="budget_overrun" string="Ueber Budget" domain="[('budget_state', '=', 'red')]"/>
                <filter name="budget_warning" string="Beobachten" domain="[('budget_state', '=', 'yellow')]"/>
                <filter name="budget_alerts" string="Warnungen" domain="[('budget_state', 'in', ['yellow', 'red'])]"/>
                <filter name="not_notified" string="Noch nicht gemeldet" domain="['|', ('last_notified_state', '=', False), ('last_notified_state', '!=', 'budget_state')]"/>
                <filter name="group_department" string="Nach Abteilung" context="{'group_by': 'department_id'}"/>
                <filter name="group_cost_center" string="Nach Kostenstelle" context="{'group_by': 'code'}"/>
            </search>
        </field>
    </record>

    <record id="action_contract_cost_center_budget" model="ir.actions.act_window">
        <field name="name">Kostenstellenbudgets</field>
        <field name="res_model">contract.cost.center.budget</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_id" ref="view_contract_cost_center_budget_kanban"/>
        <field name="search_view_id" ref="view_contract_cost_center_budget_search"/>
        <field name="context">
            {
                'search_default_budget_alerts': 1
            }
        </field>
    </record>

    <record id="action_contract_budget_dashboard" model="ir.actions.act_window">
        <field name="name">Budgetampeln</field>
        <field name="res_model">contract.cost.center.budget</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_id" ref="view_contract_cost_center_budget_kanban"/>
        <field name="search_view_id" ref="view_contract_cost_center_budget_search"/>
        <field name="context">
            {
                'search_default_budget_alerts': 1,
                'search_default_group_department': 1
            }
        </field>
    </record>
</odoo>
