<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_contract_attachment_rename_wizard_form" model="ir.ui.view">
        <field name="name">contract.attachment.rename.wizard.form</field>
        <field name="model">contract.attachment.rename.wizard</field>
        <field name="arch" type="xml">
            <form string="Dateiname ändern">
                <group>
                    <field name="contract_id" readonly="1"/>
                    <field name="current_name" readonly="1"/>
                    <field name="new_name"/>
                </group>
                <footer>
                    <button string="Speichern" type="object" name="action_apply" class="btn-primary"/>
                    <button string="Abbrechen" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
