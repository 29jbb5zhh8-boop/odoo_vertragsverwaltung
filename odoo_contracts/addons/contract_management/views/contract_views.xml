<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_contract_contract_tree" model="ir.ui.view">
        <field name="name">contract.contract.tree</field>
        <field name="model">contract.contract</field>
        <field name="arch" type="xml">
            <list string="Verträge">
                <field name="expiry_status" widget="badge" optional="show"/>
                <field name="contract_number" optional="show"/>
                <field name="name" optional="show"/>
                <field name="template_id" optional="show"/>
                <field name="contract_kind" optional="show"/>
                <field name="partner_id" optional="show"/>
                <field name="contract_value" optional="show"/>
                <field name="normalized_monthly_value" optional="show"/>
                <field name="normalized_annual_value" optional="show"/>
                <field name="currency_id" optional="hide"/>
                <field name="payment_interval" optional="show"/>
                <field name="cost_center" optional="show"/>
                <field name="cost_center_budget_state" widget="badge" optional="show"/>
                <field name="type_id" optional="show"/>
                <field name="category_id" optional="show"/>
                <field name="responsible_user_id" optional="show"/>
                <field name="approval_user_id" optional="show"/>
                <field name="manager_approval_user_id" optional="show"/>
                <field name="approval_state" widget="badge" optional="show"/>
                <field name="requires_manager_approval" optional="show"/>
                <field name="department_id" optional="show"/>
                <field name="start_date" optional="show" widget="date" options="{'datepicker': {'format': 'DD.MM.YYYY'}}"/>
                <field name="end_date" optional="show" widget="date" options="{'datepicker': {'format': 'DD.MM.YYYY'}}"/>
                <field name="termination_notice_months" optional="show"/>
                <field name="earliest_termination_date" optional="show" widget="date" options="{'datepicker': {'format': 'DD.MM.YYYY'}}"/>
                <field name="auto_renew" optional="show"/>
                <field name="renewal_period_months" optional="show"/>
                <field name="next_end_date" optional="show" widget="date" options="{'datepicker': {'format': 'DD.MM.YYYY'}}"/>
                <field name="reminder_rule_ids" optional="show"/>
                <field name="state" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_contract_contract_kanban" model="ir.ui.view">
        <field name="name">contract.contract.kanban</field>
        <field name="model">contract.contract</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile o_kanban_small_column" default_group_by="approval_state">
                <field name="name"/>
                <field name="contract_number"/>
                <field name="partner_id"/>
                <field name="contract_kind"/>
                <field name="contract_value"/>
                <field name="normalized_monthly_value"/>
                <field name="normalized_annual_value"/>
                <field name="currency_id"/>
                <field name="end_date"/>
                <field name="approval_state"/>
                <field name="expiry_status"/>
                <field name="cost_center_budget_state"/>
                <field name="requires_manager_approval"/>
                <field name="responsible_user_id"/>
                <field name="approval_user_id"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong>
                                        <field name="name"/>
                                    </strong>
                                    <div class="text-muted">
                                        <field name="contract_number"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <strong>Partner:</strong>
                                    <field name="partner_id"/>
                                </div>
                                <div>
                                    <strong>Art:</strong>
                                    <field name="contract_kind"/>
                                </div>
                                <div>
                                    <strong>Wert:</strong>
                                    <field name="contract_value"/>
                                </div>
                                <div>
                                    <strong>Monat:</strong>
                                    <field name="normalized_monthly_value"/>
                                </div>
                                <div>
                                    <strong>Ende:</strong>
                                    <field name="end_date"/>
                                </div>
                                <div>
                                    <strong>Ampel:</strong>
                                    <field name="expiry_status" widget="badge"/>
                                </div>
                                <div invisible="not cost_center_budget_state">
                                    <strong>Budget:</strong>
                                    <field name="cost_center_budget_state" widget="badge"/>
                                </div>
                                <div>
                                    <strong>Freigeber:</strong>
                                    <field name="approval_user_id"/>
                                </div>
                                <div invisible="not requires_manager_approval">
                                    <strong>Manager-Freigabe:</strong>
                                    <field name="requires_manager_approval"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="text-muted">
                                    <field name="responsible_user_id"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_contract_contract_pivot" model="ir.ui.view">
        <field name="name">contract.contract.pivot</field>
        <field name="model">contract.contract</field>
        <field name="arch" type="xml">
            <pivot string="Vertragsauswertung">
                <field name="contract_kind" type="row"/>
                <field name="payment_interval" type="col"/>
                <field name="department_id" type="row"/>
                <field name="contract_value" type="measure"/>
                <field name="normalized_monthly_value" type="measure"/>
                <field name="normalized_annual_value" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_contract_contract_graph" model="ir.ui.view">
        <field name="name">contract.contract.graph</field>
        <field name="model">contract.contract</field>
        <field name="arch" type="xml">
            <graph string="Vertragsvolumen" type="bar">
                <field name="contract_kind"/>
                <field name="normalized_annual_value" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_contract_attachment_tree" model="ir.ui.view">
        <field name="name">contract.attachment.tree</field>
        <field name="model">ir.attachment</field>
        <field name="arch" type="xml">
            <list string="Anhänge">
                <button name="action_download" type="object" icon="fa-file-pdf-o" string="" title="PDF öffnen"/>
                <button name="action_download_file" type="object" icon="fa-download" string="" title="Download"/>
                <button name="action_rename_attachment" type="object" icon="fa-pencil" string="" title="Dateiname ändern"/>
                <field name="name" string="Datei" optional="show"/>
                <field name="internal_name" string="Interner Name" optional="show"/>
                <field name="version_label" string="Version" optional="show"/>
                <field name="file_size" string="Größe" optional="show"/>
                <field name="create_date" string="Hochgeladen am" optional="show"/>
                <field name="create_uid" string="Hochgeladen von" optional="show"/>
                <field name="is_current" widget="boolean_toggle" string="Aktuell" optional="show"/>
                <field name="show_in_contract" widget="boolean_toggle" string="Sichtbar" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_contract_attachment_search" model="ir.ui.view">
        <field name="name">contract.attachment.search</field>
        <field name="model">ir.attachment</field>
        <field name="arch" type="xml">
            <search string="Anhänge">
                <field name="name"/>
                <field name="res_model"/>
                <field name="create_uid"/>
                <filter name="contract_attachments" string="Contract Anhänge" domain="[('res_model','=','contract.contract')]"/>
            </search>
        </field>
    </record>

    <record id="action_contract_attachments" model="ir.actions.act_window">
        <field name="name">Anhänge</field>
        <field name="res_model">ir.attachment</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_contract_attachment_tree"/>
        <field name="search_view_id" ref="view_contract_attachment_search"/>
        <field name="domain">[('res_model','=','contract.contract')]</field>
    </record>

    <record id="view_contract_contract_form" model="ir.ui.view">
        <field name="name">contract.contract.form</field>
        <field name="model">contract.contract</field>
        <field name="arch" type="xml">
            <form string="Vertrag">
                <header>
                    <button name="action_submit_for_approval" type="object" string="Zur Freigabe einreichen" class="btn-secondary" invisible="approval_state not in ['draft', 'rejected']"/>
                    <button name="action_open_approve_wizard" type="object" string="Freigeben" class="btn-primary" groups="contract_management.group_contract_approver,contract_management.group_contract_manager" invisible="approval_state not in ['pending', 'pending_manager']"/>
                    <button name="action_open_reject_wizard" type="object" string="Ablehnen" class="btn-secondary" groups="contract_management.group_contract_approver,contract_management.group_contract_manager" invisible="approval_state not in ['pending', 'pending_manager']"/>
                    <button name="action_activate" type="object" string="Aktivieren" class="btn-primary" invisible="state != 'draft' or approval_state != 'approved'"/>
                    <button name="%(contract_management.action_contract_cancel_wizard)d" type="action" string="Kündigen" class="btn-secondary" invisible="state in ['cancelled']" context="{'default_contract_id': id}"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,expiring,expired,cancelled"/>
                    <field name="approval_state" widget="statusbar" statusbar_visible="draft,pending,pending_manager,approved,rejected"/>
                </header>
                <sheet>
                    <div class="cm-contract-form">
                        <div class="cm-contract-hero">
                            <div class="cm-contract-hero-main">
                                <div class="cm-contract-eyebrow">Vertrag</div>
                                <field name="name" class="cm-contract-title"/>
                                <div class="cm-contract-meta">
                                    <div class="cm-contract-meta-item">
                                        <span class="cm-contract-meta-label">Vertragsnummer</span>
                                        <field name="contract_number" readonly="1" nolabel="1"/>
                                    </div>
                                    <div class="cm-contract-meta-item" invisible="not template_id">
                                        <span class="cm-contract-meta-label">Vorlage</span>
                                        <field name="template_id" nolabel="1" readonly="1"/>
                                    </div>
                                    <div class="cm-contract-meta-item">
                                        <span class="cm-contract-meta-label">Vertragspartner</span>
                                        <field name="partner_id" nolabel="1"/>
                                    </div>
                                    <div class="cm-contract-meta-item">
                                        <span class="cm-contract-meta-label">Vertragsart</span>
                                        <field name="contract_kind" nolabel="1"/>
                                    </div>
                                    <div class="cm-contract-meta-item">
                                        <span class="cm-contract-meta-label">Verantwortlich</span>
                                        <field name="responsible_user_id" nolabel="1"/>
                                    </div>
                                    <div class="cm-contract-meta-item">
                                        <span class="cm-contract-meta-label">Freigeber</span>
                                        <field name="approval_user_id" nolabel="1"/>
                                    </div>
                                    <div class="cm-contract-meta-item" invisible="not requires_manager_approval">
                                        <span class="cm-contract-meta-label">Manager-Freigeber</span>
                                        <field name="manager_approval_user_id" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                            <div class="cm-contract-aside-card">
                                <div class="cm-contract-card-title">Übersicht</div>
                                <div class="cm-contract-aside-line">
                                    <span class="cm-contract-summary-label">Status</span>
                                    <field name="state" widget="badge" nolabel="1" readonly="1"/>
                                </div>
                                <div class="cm-contract-aside-line">
                                    <span class="cm-contract-summary-label">Freigabe</span>
                                    <field name="approval_state" widget="badge" nolabel="1" readonly="1"/>
                                </div>
                                <div class="cm-contract-aside-line">
                                    <span class="cm-contract-summary-label">Ampel</span>
                                    <field name="expiry_status" widget="badge" nolabel="1" readonly="1"/>
                                </div>
                                <div class="cm-contract-aside-line">
                                    <span class="cm-contract-summary-label">Enddatum</span>
                                    <field name="end_date" widget="date" options="{'datepicker': {'format': 'DD.MM.YYYY'}}" nolabel="1" readonly="1"/>
                                </div>
                            </div>
                        </div>

                        <div class="cm-contract-kpi-strip">
                            <div class="cm-contract-summary-item">
                                <span class="cm-contract-summary-label">Start</span>
                                <field name="start_date" widget="date" options="{'datepicker': {'format': 'DD.MM.YYYY'}}" nolabel="1"/>
                            </div>
                            <div class="cm-contract-summary-item">
                                <span class="cm-contract-summary-label">Kündbar ab</span>
                                <field name="earliest_termination_date" nolabel="1" readonly="1"/>
                            </div>
                            <div class="cm-contract-summary-item">
                                <span class="cm-contract-summary-label">Frist</span>
                                <field name="termination_notice_months" nolabel="1"/>
                            </div>
                            <div class="cm-contract-summary-item">
                                <span class="cm-contract-summary-label">Verlängerung</span>
                                <field name="auto_renew" nolabel="1"/>
                            </div>
                            <div class="cm-contract-summary-item">
                                <span class="cm-contract-summary-label">Nächstes Enddatum</span>
                                <field name="next_end_date" nolabel="1" readonly="1"/>
                            </div>
                            <div class="cm-contract-summary-item">
                                <span class="cm-contract-summary-label">Erinnerungen</span>
                                <field name="reminder_rule_ids" widget="many2many_tags" nolabel="1"/>
                            </div>
                            <div class="cm-contract-summary-item">
                                <span class="cm-contract-summary-label">Vertragswert</span>
                                <field name="contract_value" nolabel="1"/>
                            </div>
                            <div class="cm-contract-summary-item">
                                <span class="cm-contract-summary-label">Monatswert</span>
                                <field name="normalized_monthly_value" nolabel="1"/>
                            </div>
                            <div class="cm-contract-summary-item">
                                <span class="cm-contract-summary-label">Jahreswert</span>
                                <field name="normalized_annual_value" nolabel="1"/>
                            </div>
                            <div class="cm-contract-summary-item">
                                <span class="cm-contract-summary-label">Manager-Pruefung</span>
                                <field name="requires_manager_approval" nolabel="1"/>
                            </div>
                            <div class="cm-contract-summary-item" invisible="not cost_center_budget_id">
                                <span class="cm-contract-summary-label">Budgetstatus</span>
                                <field name="cost_center_budget_state" widget="badge" nolabel="1" readonly="1"/>
                            </div>
                        </div>

                        <div class="cm-contract-grid">
                            <div class="cm-contract-main">
                                <div class="cm-contract-card">
                                    <div class="cm-contract-card-title">Vertragsdaten</div>
                                    <group col="2">
                                        <group>
                                            <field name="template_id" string="Vorlage"/>
                                            <field name="contract_number" string="Nummer" readonly="1" style="color: var(--o-main-text-color);"/>
                                            <field name="name" string="Titel"/>
                                            <field name="partner_id" string="Partner"/>
                                            <field name="contract_kind" string="Vertragsart"/>
                                        </group>
                                        <group>
                                            <field name="category_id" string="Kategorie"/>
                                            <field name="type_id" string="Typ"/>
                                            <field name="department_id" string="Abteilung"/>
                                        </group>
                                    </group>
                                </div>

                                <div class="cm-contract-card">
                                    <div class="cm-contract-card-title">Verantwortung &amp; Freigabe</div>
                                    <group col="2">
                                        <group>
                                            <field name="responsible_user_id" string="Verantwortlich"/>
                                            <field name="approval_user_id" string="Freigeber"/>
                                            <field name="manager_approval_user_id" string="Manager-Freigeber" invisible="not requires_manager_approval"/>
                                            <field name="approval_state" string="Freigabestatus" readonly="1"/>
                                            <field name="requires_manager_approval" string="Manager-Pruefung noetig" readonly="1"/>
                                            <field name="approval_decided_by_id" string="Entschieden von" readonly="1"/>
                                        </group>
                                        <group>
                                            <field name="submitted_for_approval_at" string="Eingereicht am" readonly="1"/>
                                            <field name="approved_at" string="Freigegeben am" readonly="1"/>
                                            <field name="manager_approved_at" string="Manager-freigegeben am" readonly="1" invisible="not manager_approved_at"/>
                                        </group>
                                    </group>
                                    <group col="1">
                                        <field name="approval_comment" string="Freigabekommentar" readonly="1" invisible="not approval_comment"/>
                                        <field name="manager_approval_comment" string="Manager-Kommentar" readonly="1" invisible="not manager_approval_comment"/>
                                        <field name="rejection_reason" string="Ablehnungsgrund" readonly="1" invisible="not rejection_reason"/>
                                    </group>
                                </div>

                                <div class="cm-contract-card">
                                    <div class="cm-contract-card-title">Kaufmaennische Daten</div>
                                    <group col="2">
                                        <group>
                                            <field name="contract_value" string="Vertragswert"/>
                                            <field name="normalized_monthly_value" string="Monatswert" readonly="1"/>
                                            <field name="normalized_annual_value" string="Jahreswert" readonly="1"/>
                                            <field name="currency_id" string="Waehrung"/>
                                        </group>
                                        <group>
                                            <field name="payment_interval" string="Zahlungsintervall"/>
                                            <field name="cost_center" string="Kostenstelle"/>
                                            <field name="cost_center_budget_id" string="Budget" readonly="1" invisible="not cost_center_budget_id"/>
                                            <field name="cost_center_budget_state" string="Budgetstatus" widget="badge" readonly="1" invisible="not cost_center_budget_id"/>
                                        </group>
                                    </group>
                                    <group col="2" invisible="not cost_center_budget_id">
                                        <group>
                                            <field name="cost_center_monthly_budget" string="Budget monatlich" readonly="1"/>
                                            <field name="cost_center_committed_monthly" string="Ist monatlich" readonly="1"/>
                                        </group>
                                        <group>
                                            <field name="cost_center_annual_budget" string="Budget jaehrlich" readonly="1"/>
                                            <field name="cost_center_committed_annual" string="Ist jaehrlich" readonly="1"/>
                                        </group>
                                    </group>
                                </div>

                                <div class="cm-contract-card">
                                    <div class="cm-contract-card-title">Notizen</div>
                                    <group col="1">
                                        <field name="note" nolabel="1" style="width: 100%; min-height: 220px;"/>
                                    </group>
                                </div>
                            </div>

                            <div class="cm-contract-side">
                                <div class="cm-contract-card">
                                    <div class="cm-contract-card-title">Aktionen</div>
                                    <div class="cm-contract-actions">
                                        <button name="action_renew" type="object" string="Verlängern" class="btn btn-primary" invisible="not end_date"/>
                                        <button name="action_set_expired" type="object" string="Als abgelaufen markieren" class="btn btn-secondary" invisible="state not in ['active', 'expiring']"/>
                                        <button name="action_reset_draft" type="object" string="Auf Entwurf setzen" class="btn btn-secondary" invisible="state not in ['cancelled', 'expired']"/>
                                        <button name="action_print_pdf_with_attachments" type="object" string="PDF drucken" class="btn btn-secondary"/>
                                        <button name="action_toggle_chatter" type="object" string="Chatter ausblenden" class="btn btn-secondary" invisible="show_chatter == False"/>
                                        <button name="action_toggle_chatter" type="object" string="Chatter einblenden" class="btn btn-secondary" invisible="show_chatter == True"/>
                                    </div>
                                </div>

                                <div class="cm-contract-card cm-contract-card-accent">
                                    <div class="cm-contract-card-title">Fristen</div>
                                    <group col="1">
                                        <field name="start_date" string="Start" widget="date" options="{'datepicker': {'format': 'DD.MM.YYYY'}}"/>
                                        <field name="end_date" string="Ende" widget="date" options="{'datepicker': {'format': 'DD.MM.YYYY'}}"/>
                                        <field name="termination_notice_months" string="Kündigungsfrist"/>
                                        <field name="earliest_termination_date" string="Kündbar ab" readonly="1"/>
                                    </group>
                                </div>

                                <div class="cm-contract-card">
                                    <div class="cm-contract-card-title">Automatik</div>
                                    <group col="1">
                                        <field name="auto_renew" string="Automatisch verlängern"/>
                                        <field name="renewal_period_months" string="Intervall (Monate)" invisible="not auto_renew"/>
                                        <field name="next_end_date" string="Nächstes Ende" readonly="1"/>
                                    </group>
                                </div>

                                <div class="cm-contract-card">
                                    <div class="cm-contract-card-title">Finanzen</div>
                                    <group col="1">
                                        <field name="contract_value" string="Vertragswert"/>
                                        <field name="normalized_monthly_value" string="Monatswert" readonly="1"/>
                                        <field name="normalized_annual_value" string="Jahreswert" readonly="1"/>
                                        <field name="currency_id" string="Waehrung"/>
                                        <field name="payment_interval" string="Zahlungsintervall"/>
                                        <field name="cost_center" string="Kostenstelle"/>
                                    </group>
                                </div>

                                <div class="cm-contract-card">
                                    <div class="cm-contract-card-title">Hinweise</div>
                                    <group col="1">
                                        <field name="reminder_rule_ids" string="Erinnerungen" widget="many2many_tags"/>
                                        <field name="cancellation_reason" string="Kündigungsgrund" readonly="1"/>
                                    </group>
                                </div>
                            </div>
                        </div>

                        <div class="cm-contract-card">
                            <div class="cm-contract-card-title">Freigabeprotokoll</div>
                            <field name="approval_log_ids" readonly="1" nolabel="1">
                                <list string="Freigabeprotokoll" create="false" edit="false" delete="false">
                                    <field name="decided_at"/>
                                    <field name="stage" widget="badge"/>
                                    <field name="decision" widget="badge"/>
                                    <field name="actor_user_id"/>
                                    <field name="assigned_user_id"/>
                                    <field name="approval_state_after" widget="badge"/>
                                    <field name="decision_comment"/>
                                </list>
                            </field>
                        </div>

                        <div name="cm_contract_timeline_anchor"/>

                        <div class="cm-contract-card cm-contract-attachments-card">
                            <div class="cm-contract-card-title">Anhänge</div>
                            <div class="cm-contract-card-subtitle">Gueltige Fassung und komplette Dokumenthistorie an einem Ort</div>
                            <div class="cm-attachment-layout">
                                <div class="cm-attachment-dropzone">
                                    <div class="cm-dropzone-title">PDFs oder Bilder hierhin ziehen</div>
                                    <div class="text-muted" style="text-align: center; margin-bottom: 8px;">
                                        Oder den Upload-Button nutzen
                                    </div>
                                    <div class="text-muted" style="text-align: center; margin-bottom: 8px;">
                                        Erlaubt: PDF, PNG, JPG, JPEG, WEBP, BMP, TIF, TIFF, GIF
                                    </div>
                                    <field
                                        name="attachment_ids"
                                        widget="many2many_binary"
                                        context="{'default_res_model': 'contract.contract', 'default_res_id': id}"
                                        options="{'accepted_file_extensions': '.pdf,.png,.jpg,.jpeg,.webp,.bmp,.tif,.tiff,.gif'}"
                                    />
                                </div>
                                <div class="cm-attachment-panels">
                                    <div class="cm-attachment-table mt16">
                                        <div class="cm-attachment-section-title">Gueltige Vertragsfassung</div>
                                        <field
                                            name="attachment_ids"
                                            domain="[('show_in_contract','=',True)]"
                                            context="{'default_res_model': 'contract.contract', 'default_res_id': id}"
                                            options="{'no_create': True, 'no_create_edit': True, 'no_quick_create': True, 'no_open': True}"
                                        >
                                            <list string="Gueltige Vertragsfassung" create="false" edit="true" delete="true" class="cm-attachment-list">
                                                <button name="action_download" type="object" icon="fa-file-pdf-o" string="" title="PDF öffnen"/>
                                                <button name="action_download_file" type="object" icon="fa-download" string="" title="Download"/>
                                                <button name="action_rename_attachment" type="object" icon="fa-pencil" string="" title="Umbenennen"/>
                                                <field name="name" string="Datei" optional="show"/>
                                                <field name="internal_name" string="Interner Titel" optional="show"/>
                                                <field name="version_label" string="Version" optional="show"/>
                                                <field name="is_current" widget="boolean_toggle" string="Aktuell" optional="show"/>
                                                <field name="show_in_contract" widget="boolean_toggle" string="Im Vertrag" optional="show"/>
                                                <field name="create_date" string="Upload" optional="show"/>
                                                <field name="create_uid" string="Von" optional="show"/>
                                                <field name="file_size" string="Groesse" optional="show"/>
                                            </list>
                                        </field>
                                    </div>

                                    <div class="cm-attachment-table mt16">
                                        <div class="cm-attachment-section-title">Dokumentenhistorie</div>
                                        <field
                                            name="attachment_ids"
                                            context="{'default_res_model': 'contract.contract', 'default_res_id': id}"
                                            options="{'no_create': True, 'no_create_edit': True, 'no_quick_create': True, 'no_open': True}"
                                        >
                                            <list string="Dokumentenhistorie" create="false" edit="true" delete="true" class="cm-attachment-list">
                                                <button name="action_set_as_current" type="object" icon="fa-star" string="" title="Als aktuelle Fassung markieren"/>
                                                <button name="action_set_show_in_contract" type="object" icon="fa-check-square-o" string="" title="Als gueltige Vertragsfassung markieren"/>
                                                <button name="action_download" type="object" icon="fa-file-pdf-o" string="" title="PDF öffnen"/>
                                                <button name="action_download_file" type="object" icon="fa-download" string="" title="Download"/>
                                                <button name="action_rename_attachment" type="object" icon="fa-pencil" string="" title="Umbenennen"/>
                                                <field name="name" string="Datei" optional="show"/>
                                                <field name="internal_name" string="Interner Titel" optional="show"/>
                                                <field name="version_label" string="Version" optional="show"/>
                                                <field name="is_current" widget="boolean_toggle" string="Aktuell" optional="show"/>
                                                <field name="show_in_contract" widget="boolean_toggle" string="Im Vertrag" optional="show"/>
                                                <field name="ocr_state" widget="badge" string="OCR" optional="show"/>
                                                <field name="create_date" string="Upload" optional="show"/>
                                                <field name="create_uid" string="Von" optional="show"/>
                                                <field name="file_size" string="Groesse" optional="show"/>
                                            </list>
                                        </field>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <field name="show_chatter" invisible="1"/>
                </sheet>
                <chatter invisible="show_chatter == False">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_contract_contract_search" model="ir.ui.view">
        <field name="name">contract.contract.search</field>
        <field name="model">contract.contract</field>
        <field name="arch" type="xml">
            <search string="Verträge">
                <field name="contract_number"/>
                <field name="name"/>
                <field name="contract_kind"/>
                <field name="partner_id"/>
                <field name="contract_value"/>
                <field name="normalized_monthly_value"/>
                <field name="normalized_annual_value"/>
                <field name="currency_id"/>
                <field name="payment_interval"/>
                <field name="cost_center"/>
                <field name="type_id"/>
                <field name="category_id"/>
                <field name="responsible_user_id"/>
                <field name="approval_user_id"/>
                <field name="manager_approval_user_id"/>
                <field name="approval_state"/>
                <field name="requires_manager_approval"/>
                <field name="department_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="termination_notice_months"/>
                <field name="earliest_termination_date"/>
                <field name="auto_renew"/>
                <field name="renewal_period_months"/>
                <field name="next_end_date"/>
                <field name="expiry_status"/>
                <field name="fulltext" string="Volltext"/>
                <field name="state"/>
                <filter name="approval_pending" string="Zur Freigabe" domain="[('approval_state', '=', 'pending')]"/>
                <filter name="approval_approved" string="Freigegeben" domain="[('approval_state', '=', 'approved')]"/>
                <filter name="my_approvals" string="Wartet auf meine Freigabe" domain="['|', '&amp;', ('approval_state', '=', 'pending'), ('approval_user_id', '=', uid), '&amp;', ('approval_state', '=', 'pending_manager'), ('manager_approval_user_id', '=', uid)]"/>
                <filter name="manager_required" string="Manager-Freigabe noetig" domain="[('requires_manager_approval', '=', True)]"/>
                <filter name="critical_contracts" string="Kritische Verträge" domain="['|', '&amp;', ('expiry_status', '=', 'red'), ('state', 'in', ['active', 'expiring']), '&amp;', ('approval_state', 'in', ['pending', 'pending_manager']), ('contract_value', '&gt;=', 10000)]"/>
                <filter name="financial_active" string="Aktive Kosten" domain="[('state', 'in', ['active', 'expiring']), ('contract_value', '&gt;', 0)]"/>
                <filter name="recurring_costs" string="Wiederkehrende Kosten" domain="[('contract_value', '&gt;', 0), ('payment_interval', '!=', 'one_time')]"/>
                <filter name="high_commitments" string="Hohe Verpflichtungen" domain="[('contract_kind', '!=', 'customer'), ('contract_value', '&gt;=', 10000)]"/>
                <filter name="high_monthly_burn" string="Hoher Monatswert" domain="[('normalized_monthly_value', '&gt;=', 1000)]"/>
                <filter name="high_annual_burn" string="Hoher Jahreswert" domain="[('normalized_annual_value', '&gt;=', 12000)]"/>
                <filter name="customer_contracts" string="Kundenverträge" domain="[('contract_kind', '=', 'customer')]"/>
                <filter name="supplier_contracts" string="Lieferantenverträge" domain="[('contract_kind', '=', 'supplier')]"/>
                <separator/>
                <filter name="group_contract_kind" string="Nach Vertragsart" context="{'group_by': 'contract_kind'}"/>
                <filter name="group_payment_interval" string="Nach Zahlungsintervall" context="{'group_by': 'payment_interval'}"/>
                <filter name="group_cost_center" string="Nach Kostenstelle" context="{'group_by': 'cost_center'}"/>
                <filter name="group_department" string="Nach Abteilung" context="{'group_by': 'department_id'}"/>
                <filter name="expiring_30" string="Läuft in 30 Tagen" domain="[('end_date','!=',False), ('end_date','&lt;=', (context_today() + relativedelta(days=30)).strftime('%%Y-%%m-%%d')), ('end_date','&gt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                <filter name="expiring_60" string="Läuft in 60 Tagen" domain="[('end_date','!=',False), ('end_date','&lt;=', (context_today() + relativedelta(days=60)).strftime('%%Y-%%m-%%d')), ('end_date','&gt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                <filter name="expiring_90" string="Läuft in 90 Tagen" domain="[('end_date','!=',False), ('end_date','&lt;=', (context_today() + relativedelta(days=90)).strftime('%%Y-%%m-%%d')), ('end_date','&gt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
            </search>
        </field>
    </record>

    <record id="view_contract_contract_calendar" model="ir.ui.view">
