<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_contract_approval_wizard_form" model="ir.ui.view">
        <field name="name">contract.approval.wizard.form</field>
        <field name="model">contract.approval.wizard</field>
        <field name="arch" type="xml">
            <form string="Freigabeentscheidung">
                <group>
                    <field name="contract_id" readonly="1" invisible="1"/>
                    <field name="decision" widget="radio" readonly="1"/>
                    <field name="comment" placeholder="Kommentar zur Freigabe oder Ablehnung..."/>
                </group>
                <footer>
                    <button
                        name="action_confirm"
                        type="object"
                        string="Entscheidung speichern"
                        class="btn-primary"
                    />
                    <button string="Abbrechen" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
