<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_contract_approval_log_tree" model="ir.ui.view">
        <field name="name">contract.approval.log.tree</field>
        <field name="model">contract.approval.log</field>
        <field name="arch" type="xml">
            <list string="Freigabeprotokoll" create="false" edit="false" delete="false">
                <field name="decided_at"/>
                <field name="contract_number"/>
                <field name="contract_id"/>
                <field name="stage" widget="badge"/>
                <field name="decision" widget="badge"/>
                <field name="actor_user_id"/>
                <field name="assigned_user_id"/>
                <field name="approval_state_after" widget="badge"/>
                <field name="decision_comment"/>
            </list>
        </field>
    </record>

    <record id="view_contract_approval_log_search" model="ir.ui.view">
        <field name="name">contract.approval.log.search</field>
        <field name="model">contract.approval.log</field>
        <field name="arch" type="xml">
            <search string="Freigabeprotokoll">
                <field name="contract_id"/>
                <field name="actor_user_id"/>
                <field name="assigned_user_id"/>
                <filter name="submitted" string="Eingereicht" domain="[('decision', '=', 'submitted')]"/>
                <filter name="rejected" string="Abgelehnt" domain="[('decision', '=', 'rejected')]"/>
                <filter name="escalated" string="Eskaliert" domain="[('decision', '=', 'escalated')]"/>
                <filter name="group_stage" string="Nach Stufe" context="{'group_by': 'stage'}"/>
                <filter name="group_actor" string="Nach Ausloeser" context="{'group_by': 'actor_user_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_contract_approval_log" model="ir.actions.act_window">
        <field name="name">Freigabeprotokoll</field>
        <field name="res_model">contract.approval.log</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_contract_approval_log_search"/>
    </record>
</odoo>
