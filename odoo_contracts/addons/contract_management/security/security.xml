<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_contract_user" model="res.groups">
        <field name="name">Vertragsbenutzer (Lesen)</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_contract_approver" model="res.groups">
        <field name="name">Vertragsfreigeber</field>
        <field name="implied_ids" eval="[(4, ref('group_contract_user'))]"/>
    </record>

    <record id="group_contract_manager" model="res.groups">
        <field name="name">Vertragsmanager</field>
        <field name="implied_ids" eval="[(4, ref('group_contract_user'))]"/>
    </record>

    <record id="contract_rule_user_own_records" model="ir.rule">
        <field name="name">Contract user own records</field>
        <field name="model_id" ref="model_contract_contract"/>
        <field name="domain_force">['|', '|', ('responsible_user_id', '=', user.id), ('approval_user_id', '=', user.id), ('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('contract_management.group_contract_user'))]"/>
    </record>

    <record id="contract_rule_approver_records" model="ir.rule">
        <field name="name">Contract approver assigned records</field>
        <field name="model_id" ref="model_contract_contract"/>
        <field name="domain_force">['|', ('approval_user_id', '=', user.id), ('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('contract_management.group_contract_approver'))]"/>
    </record>

    <record id="contract_rule_manager_all_records" model="ir.rule">
        <field name="name">Contract manager all records</field>
        <field name="model_id" ref="model_contract_contract"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('contract_management.group_contract_manager'))]"/>
    </record>
</odoo>
